# ---------- Scoreboard ----------
# Required when using app.py (the combined web + analyzer entry point)
SCOREBOARD_URL=https://app.overlays.uno/output/YOUR_ID_HERE

# ---------- OpenAI (option A – direct API) ----------
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ---------- Azure OpenAI (option B – takes priority over OPENAI_API_KEY) ----------
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_KEY=your-azure-openai-key
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ---------- General ----------
# How often to check the scoreboard for changes, in seconds (optional, defaults to 10)
POLL_INTERVAL=10

# Request timeout in seconds (optional, defaults to 15)
REQUEST_TIMEOUT=15

# Web dashboard port (optional, defaults to 8080)
WEB_PORT=8080
