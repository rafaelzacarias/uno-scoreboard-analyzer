# OpenAI API key (required)
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI model to use for insights (optional, defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# How often to check the scoreboard for changes, in seconds (optional, defaults to 10)
POLL_INTERVAL=10

# Request timeout in seconds (optional, defaults to 15)
REQUEST_TIMEOUT=15
